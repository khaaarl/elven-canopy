# gdlint configuration for Elven Canopy.
#
# Follows gdtoolkit defaults with targeted exceptions for this codebase's
# patterns.  Run with: python/.venv/bin/gdlint godot/scripts/*.gd

# Short variable names like W and H (for image width/height) are clear in
# context.  Requiring longer names would hurt readability in pixel-drawing code.
disable:
- function-variable-name

# sprite_factory.gd is a single class with many per-species sprite generators,
# each with palette constants and drawing functions. 1000 lines is too tight.
max-file-lines: 40000

# construction_controller.gd _unhandled_input handles P/G/C shortcuts + ESC +
# Enter + mouse buttons — each with early returns. 7 returns is reasonable.
max-returns: 7

# GUT test files have one method per test case. 20 is too few for files
# with thorough test coverage.
max-public-methods: 40
