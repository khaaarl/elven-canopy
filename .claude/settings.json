{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(/**)",
      "Edit(/**/*.gd)",
      "Edit(/**/*.gdextension)",
      "Edit(/**/*.gdshader)",
      "Edit(/**/*.godot)",
      "Edit(/**/*.json)",
      "Edit(/**/*.md)",
      "Edit(/**/*.py)",
      "Edit(/**/*.rs)",
      "Edit(/**/*.sh)",
      "Edit(/**/*.toml)",
      "Edit(/**/*.tres)",
      "Edit(/**/*.tscn)",
      "Edit(/**/*.txt)",
      "Edit(/.gdlintrc)",
      "Edit(/.github/workflows/*.yml)",
      "Edit(/.gitignore)",
      "Edit(/.tmp/*)",
      "Write(/**/*.gd)",
      "Write(/**/*.gdextension)",
      "Write(/**/*.gdshader)",
      "Write(/**/*.godot)",
      "Write(/**/*.json)",
      "Write(/**/*.md)",
      "Write(/**/*.py)",
      "Write(/**/*.rs)",
      "Write(/**/*.sh)",
      "Write(/**/*.toml)",
      "Write(/**/*.tres)",
      "Write(/**/*.tscn)",
      "Write(/**/*.txt)",
      "Write(/.github/workflows/*.yml)",
      "Write(/.tmp/*)",
      "Bash(ack:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(cargo:*)",
      "Bash(cargo-clippy:*)",
      "Bash(cargo-test:*)",
      "Bash(cd:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(date:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(GIT_EDITOR=true git:*)",
      "Bash(gh api repos/khaaarl/fact-misc-stuff-temp/actions/runs/*/jobs)",
      "Bash(gh api repos/khaaarl/fact-misc-stuff-temp/actions/runs/*/jobs --jq:*)",
      "Bash(gh api repos/khaaarl/fact-misc-stuff-temp/actions/runs/*/logs)",
      "Bash(gh auth status:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(godot:*)",
      "Bash(godot4:*)",
      "Bash(godot-4:*)",
      "Bash(xvfb-run godot:*)",
      "Bash(xvfb-run godot4:*)",
      "Bash(xvfb-run godot-4:*)",
      "Bash(xvfb-run -a godot:*)",
      "Bash(xvfb-run -a godot4:*)",
      "Bash(xvfb-run -a godot-4:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(isort:*)",
      "Bash(ldd:*)",
      "Bash(ln:*)",
      "Bash(ls:*)",
      "Bash(maturin:*)",
      "Bash(mkdir:*)",
      "Bash(paste:*)",
      "Bash(perf:*)",
      "Bash(pip:*)",
      "Bash(printf:*)",
      "Bash(py --version:*)",
      "Bash(python/.venv/bin/gdformat:*)",
      "Bash(python/.venv/bin/gdlint:*)",
      "Bash(python/.venv/bin/pip:*)",
      "Bash(python/.venv/bin/python:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pre-commit run:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(rustc:*)",
      "Bash(ruff:*)",
      "Bash(scripts/build.py:*)",
      "Bash(python3 scripts/build.py:*)",
      "Bash(python scripts/build.py:*)",
      "Bash(scripts/wait-for-ci.sh:*)",
      "Bash(sed:*)",
      "Bash(tail:*)",
      "Bash(tee:*)",
      "Bash(test:*)",
      "Bash(timeout:*)",
      "Bash(ty:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(xargs dirname:*)",
      "Bash(xxd:*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
    ]
  },
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "sandbox": {
    "enabled": false,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "excludedCommands": [],
    "filesystem": {
      "denyRead": ["/"],
      "allowRead": [
        "/bin",
        "/lib",
        "/lib64",
        "/usr",
        "/snap",
        "~/.cargo",
        "~/.rustup",
        "~/.local",
        "~/.cache/pip",
        "~/.pyenv",
        "~/.gitconfig",
        "~/.config/git",
        "."
      ]
    }
  }
}
